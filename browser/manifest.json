{
  "manifest_version": 3,
  "name": "FIS BIL — Behavioral Intelligence",
  "version": "0.1.0",
  "description": "Captures browsing behavior for the FIS Behavioral Intelligence Layer",
  "permissions": ["tabs", "bookmarks", "activeTab", "storage"],
  "host_permissions": ["http://localhost:8420/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
